{
	"name": "tkati (dev)",
	"dockerComposeFile": "docker-compose.devcontainer.yml",
	"service": "dev",
	"workspaceFolder": "/workspace",
	"features": {
	    "ghcr.io/epoch8/devcontainer-features/homebrew-packages:0.3.0": {
			"packages": "uv jj claude-code ktea"
	    },
		"ghcr.io/ProxayFox/devcontainer-features/clickhouse-local:1": {},
		"ghcr.io/devcontainers-extra/features/apt-packages:1": {
			"packages": "git git-lfs curl ssh make less"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff",
				"tamasfe.even-better-toml",
				"ms-python.mypy-type-checker",
				"typespec.typespec-vscode",
				"visualjj.visualjj"
			],
			"settings": {
				"python.defaultInterpreterPath": ".venv/bin/python",
				"python.testing.pytestEnabled": true
			}
		}
	},
	"remoteUser": "vscode",
	"updateRemoteUserUID": true,
	"postCreateCommand": "uv sync --all-packages --dev"
}