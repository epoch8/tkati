{
	"name": "soax-data-processing (dev)",
	"dockerComposeFile": "docker-compose.devcontainer.yml",
	"service": "dev",
	"workspaceFolder": "/workspace",
	"features": {
		"ghcr.io/devcontainers-extra/features/uv:1": {},
		"ghcr.io/devcontainers-extra/features/apt-packages:1": {
			"packages": "git git-lfs curl ssh make less"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/ProxayFox/devcontainer-features/clickhouse-local:1": {},
		"ghcr.io/devcontainers-extra/features/claude-code:1": {},
		"ghcr.io/devcontainer-community/devcontainer-features/jj-vcs.dev:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff",
				"tamasfe.even-better-toml",
				"ms-python.mypy-type-checker",
				"typespec.typespec-vscode",
				"visualjj.visualjj"
			],
			"settings": {
				"python.defaultInterpreterPath": ".venv/bin/python",
				"python.testing.pytestEnabled": true
			}
		}
	},
	"remoteUser": "vscode",
	"updateRemoteUserUID": true,
	"postCreateCommand": "uv sync --all-packages --dev"
}